# CloudOps Dashboard - Environment Variables Template
# Copy this file to .env and fill in the actual values. DO NOT commit .env!

# === Database ===
DB_URL=jdbc:postgresql://localhost:5432/cloudopsdb
DB_USERNAME=cloudops
DB_PASSWORD=your_secure_db_password
POSTGRES_DB=cloudopsdb
POSTGRES_USER=cloudops
POSTGRES_PASSWORD=your_secure_db_password

# === Security ===
# Must be at least 32 characters long
JWT_SECRET=your_super_secret_jwt_key_that_is_long_enough_for_hs512

# === Google Cloud (Optional for local) ===
GOOGLE_CLOUD_PROJECT=your-gcp-project-id

# === Frontend ===
# The URL where the backend is hosted (used by Docker Compose and Render/Railway)
BACKEND_URL=http://backend:8080
